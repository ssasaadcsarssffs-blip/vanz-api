{
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/docs",
      "dest": "/index.html"
    },
    {
      "src": "/documentation",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/index.html"
    },
    {
      "src": "/endpoints",
      "dest": "/index.html"
    },
    {
      "src": "/status",
      "dest": "/index.html"
    },
    {
      "src": "/changelog",
      "dest": "/index.html"
    },
    {
      "src": "/contact",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}
